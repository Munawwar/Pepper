{
	"compilerOptions": {
		"target": "ES2023",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"allowJs": true,
		"checkJs": true,
		"strict": true,
		"noEmit": true,
		"lib": ["DOM", "DOM.Iterable", "ES2023"],
		"plugins": [{"name": "pepper-typescript-plugin"}]
	},
	"include": ["src/**/*"]
}
