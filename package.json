{
  "name": "@pepper-js/pepper",
  "version": "0.2.5",
  "description": "Bring your server-side templates to life",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "directories": {
    "test": "test"
  },
  "scripts": {
    "build": "rm -fr dist && mkdir -p dist && esbuild src/index.js --outfile=dist/index.js --bundle --target=es2022 --format=esm --sourcemap",
    "demo": " browser-sync start --server --port 3005 --startPath=examples/plain/test.html --watch --files=pepper.js,examples",
    "lint": "npx oxlint@^1.62.0 src examples",
    "lint:fix": "npx oxlint@^1.62.0 --fix src examples"
  },
  "keywords": [
    "sprinkle some js"
  ],
  "author": "Munawwar",
  "license": "MIT",
  "devDependencies": {
    "browser-sync": "^2.29.1",
    "esbuild": "^0.28.0"
  },
  "repository": "github:Munawwar/pepper"
}
