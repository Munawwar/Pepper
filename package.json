{
  "name": "@pepper-js/pepper",
  "version": "0.2.5",
  "description": "Declarative DOM templates and function components with SSR and pseudo-hydration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./dist/index.js"
    },
    "./ssr": {
      "types": "./pepper-ssr.d.ts",
      "default": "./dist/ssr.js"
    },
    "./store": {
      "types": "./pepper-store.d.ts",
      "default": "./dist/store.js"
    }
  },
  "directories": {
    "test": "test"
  },
  "scripts": {
    "build": "rm -fr dist && mkdir -p dist && esbuild src/index.js --outfile=dist/index.js --bundle --target=es2022 --format=esm --sourcemap && esbuild src/pepper-ssr.js --outfile=dist/ssr.js --bundle --target=es2022 --format=esm --sourcemap && esbuild src/store.js --outfile=dist/store.js --bundle --target=es2022 --format=esm --sourcemap",
    "demo": "browser-sync start --server --port 3005 --startPath=examples/components.html --watch --files=examples,src",
    "lint": "npm run typecheck && npm run lint:js",
    "lint:js": "npx oxlint@^1.62.0 src examples",
    "lint:fix": "npx oxlint@^1.62.0 --fix src examples",
    "lint:templates": "node tooling/pepper-lint/bin.js",
    "test:dom": "web-test-runner --config test/web-test-runner.unit.config.mjs --files test/pepper.test.js",
    "test:ssr": "node --test test/ssr.test.js",
    "test:tooling": "node --test tooling/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --pretty false --noEmit",
    "vscode:prepare": "node tooling/pepper-vscode/scripts/local-dev.js prepare",
    "vscode:package": "node tooling/pepper-vscode/scripts/local-dev.js package",
    "vscode:install": "node tooling/pepper-vscode/scripts/local-dev.js install",
    "vscode:dev": "node tooling/pepper-vscode/scripts/local-dev.js dev"
  },
  "keywords": [
    "html",
    "ssr",
    "hydration",
    "components"
  ],
  "author": "Munawwar",
  "license": "MIT",
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@web/dev-server-import-maps": "^0.2.1",
    "@web/test-runner": "^0.20.2",
    "browser-sync": "^2.29.1",
    "esbuild": "^0.28.0",
    "five-server": "^0.4.4",
    "solid-js": "^1.9.9",
    "typescript": "^5.9.2"
  },
  "repository": "github:Munawwar/pepper"
}
